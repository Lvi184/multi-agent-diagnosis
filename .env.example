# ============================================
# MoodAngels v2.0 环境配置文件
# ============================================

# ===== 基础配置 =====
APP_NAME=MoodAngels - AI 心理健康筛查系统
APP_ENV=development
DEBUG=true

# ===== 安全配置（生产环境必须修改！）=====
# 生成方法：openssl rand -hex 32
SECRET_KEY=your-32-char-secret-key-change-in-production-please

# ===== JWT 配置 =====
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240   # 4小时
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7          # 7天

# ===== 数据库配置 =====
# SQLite（开发/演示）
DB_ENGINE=sqlite

# PostgreSQL（生产环境）
# DB_ENGINE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=moodangels

# ===== CORS 配置 =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== Swagger 文档保护 =====
SWAGGER_UI_USERNAME=admin
SWAGGER_UI_PASSWORD=change-in-production

# ===== AI 模型配置 =====
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
DEFAULT_MODEL=gpt-3.5-turbo

# ===== 日志配置 =====
LOG_LEVEL=INFO
